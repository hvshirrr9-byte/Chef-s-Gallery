rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Reuseable global helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Rules for User Pantries
    match /pantries/{userId} {
      allow get: if isOwner(userId);
      allow create, update: if isOwner(userId) 
        && incoming().userId == userId
        && incoming().ingredients is list
        && incoming().ingredients.size() <= 100;
      allow delete: if isOwner(userId);
    }

    // Rules for Favorite Recipes
    match /favorites/{favoriteId} {
      allow read: if isSignedIn() && (existing() == null || existing().userId == request.auth.uid);
      allow create: if isSignedIn() 
        && incoming().userId == request.auth.uid
        && incoming().recipeId is int
        && incoming().title is string && incoming().title.size() <= 200;
      allow update: if false; // Favorites are immutable, you delete and create them
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
  }
}
